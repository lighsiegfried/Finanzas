<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-backup rules for Android 11 and lower (API <= 30).
  Everything sensitive is excluded: the Room database, its journals, shared prefs,
  DataStore files and any other app file. Combined with allowBackup="false" this is
  defense in depth against unintended cloud backup.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
