<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Local-only personal finance app.
      No INTERNET or other network permissions are declared on purpose:
      financial data must never leave the device.
    -->

    <!-- solo se pide al activar recordatorios, en android 13 o mayor -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      WorkManager mezcla estos permisos por defecto; se quitan porque los recordatorios
      no usan red y JobScheduler ya persiste el trabajo tras reiniciar en API 26+.
      Solo se conserva WAKE_LOCK. INTERNET nunca se declara.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" tools:node="remove" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" tools:node="remove" />

    <application
        android:name=".FinanzasApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MisFinanzas">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MisFinanzas.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          FileProvider solo para recibir la foto recien tomada por la camara en un archivo temporal
          privado; no se exporta y nunca expone los adjuntos guardados ni contenido descifrado.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- se elimina el receptor de arranque de WorkManager para no pedir RECEIVE_BOOT_COMPLETED -->
        <receiver
            android:name="androidx.work.impl.background.systemalarm.RescheduleReceiver"
            tools:node="remove" />

        <!--
          Receptores de widgets de glance. Deben estar exportados porque el launcher del sistema
          los enlaza via APPWIDGET_UPDATE; no exponen datos financieros (privacidad por defecto,
          montos ocultos) y no aceptan datos externos mas alla del broadcast del sistema.
        -->
        <receiver
            android:name=".widget.QuickActionsWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_actions_info" />
        </receiver>
        <receiver
            android:name=".widget.SummaryWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_summary_info" />
        </receiver>
        <receiver
            android:name=".widget.UpcomingPaymentsWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_upcoming_info" />
        </receiver>

    </application>

</manifest>
