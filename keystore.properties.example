# Example signing configuration for the production RELEASE build.
# Copy this file to "keystore.properties" (which is git-ignored) and fill in real values.
# NEVER commit the real keystore.properties or the .jks/.keystore file.
#
# storeFile is resolved relative to the repository root.
# If keystore.properties is absent, the release build is produced UNSIGNED (it still builds).
# If it is present but any value is blank, the build fails with a clear message.

storeFile=../keystores/mis-finanzas-release.jks
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=REPLACE_WITH_KEY_ALIAS
keyPassword=REPLACE_WITH_KEY_PASSWORD
